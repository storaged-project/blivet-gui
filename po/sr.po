msgstr ""
"Диск {name} је досегао највећи број дозвољених примарних партиција за "
"{label} ознаку диска."

#: ../blivetgui/blivetgui.py:470
msgid "Failed to add disklabel:"
msgstr "Није успело додавање натписа диска:"

#: ../blivetgui/blivetgui.py:483
#, python-brace-format
msgid "create new disklabel on {name}"
msgstr "направи нову ознаку диска на {name}"

#: ../blivetgui/blivetgui.py:535
msgid "Failed to add the device:"
msgstr "Није успело додавање уређаја:"

#: ../blivetgui/blivetgui.py:550
#, python-brace-format
msgid "add {size} {type} device"
msgstr "додај {size} {type} уређај"

