msgstr "ດຳເນີນການບໍ່ສຳເລັດ:"

#: ../blivetgui/blivetgui.py:694
msgid "Confirm scheduled actions"
msgstr "ຢືນຢັນການດຳເນີນການທີ່ກຳນົດໄວ້"

#: ../blivetgui/blivetgui.py:695
msgid "Are you sure you want to perform scheduled actions?"
msgstr "ທ່ານແນ່ໃຈບໍ່ວ່າຕ້ອງການດຳເນີນການຕາມທີ່ກຳນົດໄວ້?"

#: ../blivetgui/blivetgui.py:736
#, python-brace-format
msgid ""
"Unmount of '{mountpoint}' failed. Are you sure the device is not in use?"
msgstr ""
"ຍົກເລີກການເຊື່ອມຕໍ່ '{mountpoint}' ບໍ່ສຳເລັດ. ແນ່ໃຈບໍ່ວ່າອຸປະກອນບໍ່ໄດ້ຖືກໃຊ້ງານຢູ່?"

#: ../blivetgui/blivetgui.py:758
msgid "Unlocking failed. Are you sure provided password is correct?"
msgstr "ປົດລັອກບໍ່ສຳເລັດ. ແນ່ໃຈບໍ່ວ່າລະຫັດຜ່ານທີ່ປ້ອນນັ້ນຖືກຕ້ອງ?"

#: ../blivetgui/blivetgui.py:808 ../data/ui/blivet-gui.ui:692
msgid "Quit"
msgstr "ອອກ"

#: ../blivetgui/blivetgui.py:811
msgid "blivet-gui is already running"
msgstr "blivet-gui ກຳລັງເຮັດວຽກຢູ່ແລ້ວ"

#: ../blivetgui/blivetgui.py:812
msgid ""
"Another instance of blivet-gui is already running.\n"
"Only one instance of blivet-gui can run at the same time."
msgstr ""
"ມີ blivet-gui ອີກອັນໜຶ່ງກຳລັງເຮັດວຽກຢູ່.\n"
"ສາມາດເປີດໃຊ້ blivet-gui ໄດ້ພຽງອັນດຽວໃນເວລາດຽວກັນ."

#: ../blivetgui/blivetgui.py:814
msgid ""
"If your previous instance of blivet-gui crashed, please make sure that the "
"<i>blivet-gui-daemon</i> process was terminated too.\n"
"If it is still running you can use\n"
"\n"
"<tt>$ sudo killall blivet-gui-daemon</tt>\n"
"\n"
"command to force quit it."
msgstr ""
"ຖ້າ blivet-gui ກ່ອນໜ້ານີ້ຂັດຂ້ອງ, ກະລຸນາກວດສອບໃຫ້ແນ່ໃຈວ່າໂປຣເຊສ <i>blivet-gui-daemon</"
"i> ຖືກປິດໄປແລ້ວຄືກັນ.\n"
"ຖ້າມັນຍັງເຮັດວຽກຢູ່ ທ່ານສາມາດໃຊ້ຄຳສັ່ງ\n"
"\n"
"<tt>$ sudo killall blivet-gui-daemon</tt>\n"
"\n"
"ເພື່ອບັງຄັບໃຫ້ມັນປິດອອກ."

#: ../blivetgui/blivetgui.py:846
msgid "Failed to init blivet:"
msgstr "ເລີ່ມຕົ້ນ blivet ບໍ່ສຳເລັດ:"

#: ../blivetgui/blivetgui.py:853
msgid "Quit blivet-gui"
msgstr "ອອກຈາກ blivet-gui"

#: ../blivetgui/blivetgui.py:855
msgid "Ignore disk and continue"
msgstr "ຂ້າມດິສກ໌ນີ້ ແລະ ດຳເນີນການຕໍ່"

#: ../blivetgui/blivetgui.py:858
#, python-brace-format
msgid "Error: {error}"
msgstr "ຂໍ້ຜິດພາດ: {error}"

#: ../blivetgui/blivetgui.py:859
#, python-brace-format
msgid ""
"Blivet-gui can't use the <b>{name}</b> disk due to a corrupted/unknown "
"disklabel.\n"
"You can either quit blivet-gui now or continue without being able to use "
"this disk."
msgstr ""
"Blivet-gui ບໍ່ສາມາດໃຊ້ດິສກ໌ <b>{name}</b> ໄດ້ ເນື່ອງຈາກປ້າຍຊື່ດິສກ໌ເສຍຫາຍ ຫຼື ບໍ່ຮູ້ຈັກ.\n"
"ທ່ານສາມາດອອກຈາກ blivet-gui ດຽວນີ້ ຫຼື ດຳເນີນການຕໍ່ໂດຍບໍ່ສາມາດໃຊ້ດິສກ໌ນີ້ໄດ້."

#: ../blivetgui/blivetgui.py:895
msgid "Confirm reload storage"
msgstr "ຢືນຢັນການໂຫຼດຂໍ້ມູນບ່ອນເກັບຂໍ້ມູນໃໝ່"

#: ../blivetgui/blivetgui.py:896
msgid "There are pending operations. Are you sure you want to continue?"
msgstr "ຍັງມີການດຳເນີນການທີ່ຄ້າງຢູ່. ທ່ານແນ່ໃຈບໍ່ວ່າຕ້ອງການດຳເນີນການຕໍ່?"

#: ../blivetgui/blivetgui.py:927
msgid "Are you sure you want to quit?"
msgstr "ທ່ານແນ່ໃຈບໍ່ວ່າຕ້ອງການອອກ?"

#: ../blivetgui/blivetgui.py:928
msgid ""
"There are pending operations. Are you sure you want to quit blivet-gui now?"
msgstr ""
"ຍັງມີການດຳເນີນການທີ່ຄ້າງຢູ່. ທ່ານແນ່ໃຈບໍ່ວ່າຕ້ອງການອອກຈາກ blivet-gui ດຽວນີ້?"

#: ../blivetgui/blivet_utils.py:79
msgid "free space"
msgstr "ເນື້ອທີ່ຫວ່າງ"

#: ../blivetgui/blivet_utils.py:690
#, python-brace-format
msgid "Resizing of {type} devices is currently not supported"
msgstr "ການປັບຂະໜາດອຸປະກອນ {type} ຍັງບໍ່ຮອງຮັບໃນເວລານີ້"

#: ../blivetgui/blivet_utils.py:695
msgid "Protected devices cannot be resized"
msgstr "ອຸປະກອນທີ່ຖືກປ້ອງກັນໄວ້ບໍ່ສາມາດປັບຂະໜາດໄດ້"

#: ../blivetgui/blivet_utils.py:700
msgid "Immutable formats cannot be resized"
msgstr "ຟໍແມັດທີ່ປ່ຽນແປງບໍ່ໄດ້ ບໍ່ສາມາດປັບຂະໜາດໄດ້"

#: ../blivetgui/blivet_utils.py:705
msgid "Devices with children cannot be resized"
msgstr "ອຸປະກອນທີ່ມີອຸປະກອນຍ່ອຍພ່ວງຢູ່ ບໍ່ສາມາດປັບຂະໜາດໄດ້"

#: ../blivetgui/blivet_utils.py:716
msgid "Unformatted devices are not resizable"
msgstr "ອຸປະກອນທີ່ຍັງບໍ່ທັນຟໍແມັດ ບໍ່ສາມາດປັບຂະໜາດໄດ້"

#. unfortunately we can't use format._resizable here because blivet uses it to both mark
#. formats as not resizable and force users to call update_size_info on resizable formats
#: ../blivetgui/blivet_utils.py:723
#, python-brace-format
msgid "Resizing of {type} format is currently not supported"
msgstr "ການປັບຂະໜາດຟໍແມັດ {type} ຍັງບໍ່ຮອງຮັບໃນເວລານີ້"

#: ../blivetgui/blivet_utils.py:728
#, python-brace-format
msgid "Tools for resizing format {type} are not available."
msgstr "ບໍ່ມີເຄື່ອງມືສຳລັບປັບຂະໜາດຟໍແມັດ {type}."

#. TODO: we could support this by simply changing formats target size but we'd need
#. a workaround for the missing action
#: ../blivetgui/blivet_utils.py:735
msgid "Formats scheduled to be created cannot be resized"
msgstr "ຟໍແມັດທີ່ກຳນົດຈະສ້າງໃໝ່ ບໍ່ສາມາດປັບຂະໜາດໄດ້"

#: ../blivetgui/blivet_utils.py:740
#, python-brace-format
msgid "Format {type} doesn't support updating its size limit information"
msgstr "ຟໍແມັດ {type} ບໍ່ຮອງຮັບການອັບເດດຂໍ້ມູນຂີດຈຳກັດຂະໜາດ"

#: ../blivetgui/blivet_utils.py:747
msgid "Mounted devices cannot be resized"
msgstr "ອຸປະກອນທີ່ເຊື່ອມຕໍ່ (mount) ຢູ່ ບໍ່ສາມາດປັບຂະໜາດໄດ້"

#: ../blivetgui/blivet_utils.py:752
msgid "Logical Volumes with snapshots cannot be resized."
msgstr "ບໍລິມາດໂລຈິກ (Logical Volumes) ທີ່ມີສະແນັບຊັອດ ບໍ່ສາມາດປັບຂະໜາດໄດ້."

#: ../blivetgui/blivet_utils.py:757
msgid "Resizing of LUKS2 devices is currently not supported."
msgstr "ການປັບຂະໜາດອຸປະກອນ LUKS2 ຍັງບໍ່ຮອງຮັບໃນເວລານີ້."

#: ../blivetgui/blivet_utils.py:769
#, python-brace-format
msgid "Failed to update filesystem size info: {error}"
msgstr "ອັບເດດຂໍ້ມູນຂະໜາດລະບົບໄຟລ໌ບໍ່ສຳເລັດ: {error}"

#: ../blivetgui/blivet_utils.py:788
msgid "Device is not resizable."
msgstr "ອຸປະກອນບໍ່ສາມາດປັບຂະໜາດໄດ້."

#: ../blivetgui/blivet_utils.py:790
msgid "Format is not resizable after updating its size limit information."
msgstr "ຟໍແມັດບໍ່ສາມາດປັບຂະໜາດໄດ້ ຫຼັງຈາກອັບເດດຂໍ້ມູນຂີດຈຳກັດຂະໜາດ."

#: ../blivetgui/exception_handler.py:74
#, python-brace-format
msgid ""
"Unknown error occurred.\n"
"{error}"
msgstr ""
"ເກີດຂໍ້ຜິດພາດທີ່ບໍ່ຮູ້ຈັກ.\n"
"{error}"

#: ../blivetgui/exception_handler.py:76
#, python-brace-format
msgid ""
"Unknown error occurred. Blivet-gui will be terminated.\n"
"{error}"
msgstr ""
"ເກີດຂໍ້ຜິດພາດທີ່ບໍ່ຮູ້ຈັກ. Blivet-gui ຈະຖືກປິດລົງ.\n"
"{error}"

