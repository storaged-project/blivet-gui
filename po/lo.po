msgstr "ລຶບອຸປະກອນບໍ່ສຳເລັດ:"

#: ../blivetgui/blivetgui.py:609
#, python-brace-format
msgid "delete partition {name}"
msgstr "ລຶບພາທິຊັນ {name}"

#: ../blivetgui/blivetgui.py:650
